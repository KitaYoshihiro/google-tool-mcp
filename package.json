{
  "name": "google-tool-mcp",
  "version": "0.3.0",
  "private": true,
  "description": "MCP server and CLI for reading Gmail messages and Google Drive metadata",
  "type": "commonjs",
  "license": "MIT",
  "keywords": [
    "gmail",
    "drive",
    "mcp",
    "cli",
    "google-api",
    "oauth2",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KitaYoshihiro/google-tool-mcp.git"
  },
  "homepage": "https://github.com/KitaYoshihiro/google-tool-mcp#readme",
  "bugs": {
    "url": "https://github.com/KitaYoshihiro/google-tool-mcp/issues"
  },
  "files": [
    "README.md",
    "SECURITY.md",
    "DEVELOPMENT.md",
    "bin/",
    "dist/",
    "tsconfig.json"
  ],
  "bin": {
    "google-tool": "./bin/google-tool.js",
    "google-tool-mcp": "./bin/google-tool-mcp.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "google-auth-library": "^10.4.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "node ./scripts/run-tests.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
